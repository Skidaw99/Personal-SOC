# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
POSTGRES_DB=social_fraud_detector
POSTGRES_USER=sfd_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://sfd_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/social_fraud_detector

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ─────────────────────────────────────────────
# APP SECURITY
# ─────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_FERNET_KEY
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

# ─────────────────────────────────────────────
# EMAIL ALERTS (Gmail SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
ALERT_FROM_EMAIL=your_gmail@gmail.com
ALERT_TO_EMAIL=your_alert_recipient@gmail.com

# ─────────────────────────────────────────────
# WEBHOOK (outbound alerts to your endpoint)
# ─────────────────────────────────────────────
WEBHOOK_URL= # — voor Slack/Teams/PagerDuty webhooks
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
WEBHOOK_TARGET_URL=https://your-endpoint.com/fraud-alerts

# ─────────────────────────────────────────────
# META (Facebook + Instagram)
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=CHANGE_ME_META_VERIFY_TOKEN

# ─────────────────────────────────────────────
# TWITTER / X
# ─────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_WEBHOOK_ENV_NAME=

# ─────────────────────────────────────────────
# LINKEDIN
# ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# TIKTOK
# ─────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# YOUTUBE (Google)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ─────────────────────────────────────────────
# POLLING INTERVALS (in seconds)
# ─────────────────────────────────────────────
POLLING_INTERVAL_META=300
POLLING_INTERVAL_TWITTER=180
POLLING_INTERVAL_LINKEDIN=600
POLLING_INTERVAL_TIKTOK=600
POLLING_INTERVAL_YOUTUBE=300

# ─────────────────────────────────────────────
# VIRUSTOTAL
# ─────────────────────────────────────────────
VIRUSTOTAL_API_KEY=

# ─────────────────────────────────────────────
# ABUSEIPDB
# ─────────────────────────────────────────────
ABUSEIPDB_API_KEY=

# ─────────────────────────────────────────────
# SHODAN
# ─────────────────────────────────────────────
SHODAN_API_KEY=

# ─────────────────────────────────────────────
# MAXMIND
# ─────────────────────────────────────────────
MAXMIND_DB_PATH=/data/geoip/GeoLite2-City.mmdb

# ─────────────────────────────────────────────
# CROWDSEC
# ─────────────────────────────────────────────
CROWDSEC_LAPI_URL=

PLATFORM_API_BASE_URL=
PLATFORM_API_KEY= # — voor account lock/flag
RESPONSE_DRY_RUN=true

# ─────────────────────────────────────────────
# ANTHROPIC
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_ROUTING_THRESHOLD=

# ─────────────────────────────────────────────
# OLLAMA
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=

# ─────────────────────────────────────────────
# SOC ORCHESTRATOR
# ─────────────────────────────────────────────
SOC_DATABASE_URL=postgresql+asyncpg://sfd_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/social_fraud_detector
SOC_SECRET_KEY=CHANGE_ME_SOC_SECRET
SOC_API_PORT=8001
AUTO_BLOCK_ENABLED=false
AUTO_BLOCK_THRESHOLD=75.0